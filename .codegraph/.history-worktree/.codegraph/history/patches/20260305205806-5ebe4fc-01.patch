+    [questionSetId]
+  );
+  if (!row) {
+    throw new Error("Question set not found.");
+  }
+
+  const scope = toStringValue(row.scope) === "contact" ? "contact" : "global";
+  const contactId = row.contact_id === null ? null : toNumber(row.contact_id);
